# Modular shell config
SHELL_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/shell"

source "$SHELL_CONFIG_DIR/exports.sh"
source "$SHELL_CONFIG_DIR/aliases.sh"
source "$SHELL_CONFIG_DIR/functions.sh"

# Zsh-specific hooks (starship, zoxide, fzf with zsh syntax)
if command -v starship &> /dev/null; then
  eval "$(starship init zsh)"
fi

if command -v zoxide &> /dev/null; then
  eval "$(zoxide init zsh)"
fi

if command -v fzf &> /dev/null; then
  source <(fzf --zsh) 2>/dev/null || true
fi

if command -v mise &> /dev/null; then
  eval "$(mise activate zsh)"
fi

# History settings
HISTSIZE=32768
SAVEHIST=32768
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt APPEND_HISTORY
